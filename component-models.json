      {
        "component": "select",
        "name": "media",
        "label": "Media Type",
        "valueType": "string",
        "multi": false,
        "required": true,
        "options": [
          {
            "name": "Image",
            "value": "image"
          },
          {
            "name": "Video",
            "value": "video"
          }
