        "label": "Media Asset",
        "valueType": "string",
        "required": true
      },
      {
        "component": "reference",
        "name": "logo",
        "label": "Logo",
        "valueType": "string",
        "condition": {
          "===": [
            {
              "var": "media"
            },
            "image"
          ]
        }
      },
      {
        "component": "reference",
        "name": "mediaAssetMobile",
        "label": "Media Asset (Mobile Video)",
        "valueType": "string",
        "condition": {
          "===": [
            {
              "var": "media"
            },
            "video"
          ]
        }
      },
      {
        "component": "text",
        "name": "ctaLabel",
        "label": "CTA Label",
        "valueType": "string",
        "condition": {
          "===": [
            {
              "var": "media"
            },
            "video"
          ]
        }
      },
